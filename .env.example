# ─── Database ────────────────────────────────────────────────
DB_HOST=localhost
DB_USER=admin
DB_PASS=changeme
DB_NAME=c2
MYSQL_ROOT_PASSWORD=changeme

# ─── App ─────────────────────────────────────────────────────
APP_URL=http://localhost:3000
CORS_ORIGIN=

# ─── SMTP (required — server will not start without valid credentials) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ─── Admin (required — super user credentials) ──────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_EMAIL=

# ─── Google OAuth / SSO (optional) ──────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Set authorized redirect URI to: <APP_URL>/api/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Restrict sign-in to a specific Google Workspace domain (e.g. yourcompany.com)
# When set, users from this domain can sign in and auto-create accounts without an invitation.
# Leave blank to allow any Google account to link to existing accounts only.
GOOGLE_OAUTH_DOMAIN=

# ─── GitHub Integration (optional) ──────────────────────────
# Create an OAuth App at https://github.com/settings/developers
# Set authorization callback URL to: <APP_URL>/api/oauth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
